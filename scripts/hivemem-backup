#!/bin/bash
set -euo pipefail

BACKUP_DIR="/data/backups"
DATE=$(date +%Y-%m-%d)
DUMP_FILE="$BACKUP_DIR/hivemem-$DATE.sql.gz"

mkdir -p "$BACKUP_DIR"

# Password comes from HIVEMEM_DB_PASSWORD (set by the container env).
# pg_dump uses PGPASSWORD; map it here to keep this script self-contained.
if [ -n "${HIVEMEM_DB_PASSWORD:-}" ]; then
    export PGPASSWORD="$HIVEMEM_DB_PASSWORD"
fi

DB_USER="${HIVEMEM_DB_USER:-hivemem}"
DB_NAME="${HIVEMEM_DB_NAME:-hivemem}"
# Parse host from JDBC URL if DB_HOST not set (jdbc:postgresql://host:port/db)
if [ -z "${HIVEMEM_DB_HOST:-}" ] && [ -n "${HIVEMEM_JDBC_URL:-}" ]; then
    HIVEMEM_DB_HOST=$(echo "$HIVEMEM_JDBC_URL" | sed 's|.*://||;s|:.*||;s|/.*||')
fi
DB_HOST="${HIVEMEM_DB_HOST:-localhost}"

pg_dump -U "$DB_USER" -h "$DB_HOST" "$DB_NAME" | gzip > "$DUMP_FILE"

# Keep only last 7 daily dumps
ls -t "$BACKUP_DIR"/hivemem-*.sql.gz 2>/dev/null | tail -n +8 | xargs -r rm

echo "[$(date)] Backup complete: $DUMP_FILE ($(du -h "$DUMP_FILE" | cut -f1))"
