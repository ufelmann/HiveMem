#!/bin/bash
# hivemem-token -- token management CLI for the Java runtime.
# Talks to PostgreSQL directly via psql. Mirrors the Java DbTokenService semantics:
#   * plaintext is a 32-byte URL-safe random string
#   * token_hash is its SHA-256 hex
#   * role is one of admin|writer|reader|agent
#   * expires_at is interval-based (e.g. 90d)
set -euo pipefail

if [ -n "${HIVEMEM_DB_PASSWORD:-}" ]; then
    export PGPASSWORD="$HIVEMEM_DB_PASSWORD"
fi
DB_USER="${HIVEMEM_DB_USER:-hivemem}"
DB_NAME="${HIVEMEM_DB_NAME:-hivemem}"
DB_HOST="${HIVEMEM_DB_HOST:-/var/run/postgresql}"
PSQL=(psql -U "$DB_USER" -h "$DB_HOST" -d "$DB_NAME" -v ON_ERROR_STOP=1 -q -t -A)

usage() {
    cat >&2 <<'EOF'
Usage:
  hivemem-token create <name> --role <admin|writer|reader|agent> [--expires <Nd>]
  hivemem-token list
  hivemem-token revoke <name>
  hivemem-token info <name>
EOF
    exit 2
}

valid_role() {
    case "$1" in
        admin|writer|reader|agent) return 0 ;;
        *) return 1 ;;
    esac
}

cmd_create() {
    local name="${1:-}"; shift || true
    local role=""
    local expires=""
    while [ "$#" -gt 0 ]; do
        case "$1" in
            --role) role="${2:-}"; shift 2 ;;
            --expires) expires="${2:-}"; shift 2 ;;
            *) usage ;;
        esac
    done
    [ -n "$name" ] || usage
    [ -n "$role" ] || usage
    valid_role "$role" || { echo "Error: role must be admin|writer|reader|agent" >&2; exit 1; }

    # 32-byte URL-safe plaintext (base64url, no padding) -- same shape as the Java service.
    local plaintext
    plaintext=$(openssl rand 32 | base64 | tr '+/' '-_' | tr -d '=\n')
    local token_hash
    token_hash=$(printf %s "$plaintext" | openssl dgst -sha256 | awk '{print $NF}')

    local expires_expr="NULL"
    if [ -n "$expires" ]; then
        local days="${expires%d}"
        case "$days" in
            ''|*[!0-9]*) echo "Error: --expires must look like 90d" >&2; exit 1 ;;
        esac
        expires_expr="now() + interval '${days} days'"
    fi

    "${PSQL[@]}" -v "tok_hash=${token_hash}" -v "tok_name=${name}" -v "tok_role=${role}" <<'SQL' >/dev/null
INSERT INTO api_tokens (token_hash, name, role, expires_at)
VALUES (:'tok_hash', :'tok_name', :'tok_role', NULL);
SQL
    if [ "$expires_expr" != "NULL" ]; then
        "${PSQL[@]}" -v "tok_name=${name}" <<SQL >/dev/null
UPDATE api_tokens SET expires_at = ${expires_expr} WHERE name = :'tok_name';
SQL
    fi

    cat <<EOF

============================================================
  Token created: ${name} (role: ${role})
  API token: ${plaintext}
  Save this now -- it cannot be retrieved later.
============================================================
EOF
}

cmd_list() {
    "${PSQL[@]}" -F $'\t' <<'SQL' | awk -F'\t' '
BEGIN { printf "%-20s %-10s %-10s %-20s %-20s\n", "Name", "Role", "Status", "Created", "Expires";
        printf "%s\n", "--------------------------------------------------------------------------------" }
{
    name=$1; role=$2; status=$3; created=substr($4,1,10); expires=$5;
    if (expires == "" || expires == "\\N") expires="never"; else expires=substr(expires,1,10);
    printf "%-20s %-10s %-10s %-20s %-20s\n", name, role, status, created, expires
}'
SELECT
    name,
    role,
    CASE
        WHEN revoked_at IS NOT NULL THEN 'revoked'
        WHEN expires_at IS NOT NULL AND expires_at < now() THEN 'expired'
        ELSE 'active'
    END AS status,
    created_at::text,
    coalesce(expires_at::text, '')
FROM api_tokens
ORDER BY created_at;
SQL
}

cmd_revoke() {
    local name="${1:-}"
    [ -n "$name" ] || usage
    local updated
    updated=$("${PSQL[@]}" -v "tok_name=${name}" <<'SQL'
UPDATE api_tokens SET revoked_at = now()
WHERE name = :'tok_name' AND revoked_at IS NULL
RETURNING 1;
SQL
)
    if [ -z "$updated" ]; then
        echo "Error: Token '${name}' not found or already revoked" >&2
        exit 1
    fi
    echo "Token '${name}' revoked."
}

cmd_info() {
    local name="${1:-}"
    [ -n "$name" ] || usage
    local row
    row=$("${PSQL[@]}" -F $'\t' -v "tok_name=${name}" <<'SQL'
SELECT name,
       role,
       created_at::text,
       coalesce(expires_at::text, ''),
       coalesce(revoked_at::text, '')
FROM api_tokens
WHERE name = :'tok_name';
SQL
)
    if [ -z "$row" ]; then
        echo "Token '${name}' not found." >&2
        exit 1
    fi
    local IFS=$'\t'
    # shellcheck disable=SC2162
    read -r n r c e rv <<<"$row"
    [ -z "$e" ] && e="never"
    [ -z "$rv" ] && rv="no"
    printf "Name:       %s\nRole:       %s\nCreated:    %s\nExpires:    %s\nRevoked:    %s\n" \
        "$n" "$r" "$c" "$e" "$rv"
}

main() {
    [ "$#" -ge 1 ] || usage
    local cmd="$1"; shift
    case "$cmd" in
        create) cmd_create "$@" ;;
        list)   cmd_list "$@" ;;
        revoke) cmd_revoke "$@" ;;
        info)   cmd_info "$@" ;;
        -h|--help) usage ;;
        *) usage ;;
    esac
}

main "$@"
